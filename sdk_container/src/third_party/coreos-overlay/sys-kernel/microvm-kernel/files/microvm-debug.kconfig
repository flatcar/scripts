#
# Minimal kernel config for Cloud Hypervisor microVMs
#
# Based on ch_defconfig with additions for container workloads.
# Target: < 5MB vmlinux, < 100ms boot time.
#
# This is a partial config — use with `make olddefconfig` to fill defaults.
#

# These do not seem to exist in 6.12.x
#CONFIG_CGROUP_NS
#CONFIG_CGROUP_V2

# Additional kconfig options for interactive debugging
# e.g. via
# qemu-system-x86_64 -nographic -snapshot -kernel vmlinux-microvm \
#                     -drive file=disk.ero,if=virtio,media=disk,format=raw \
#                     -append "root=/dev/vda console=ttyS0 init=/ash" \
#                     -m 1G -cpu host --enable-kvm
CONFIG_EXPERT=y
CONFIG_TTY=y
CONFIG_TTY_PRINTK=y
CONFIG_SERIAL_8250=y
CONFIG_SERIAL_8250_CONSOLE=y
CONFIG_SERIAL_8250_EXTENDED=y
CONFIG_SERIAL_8250_MANY_PORTS=y
CONFIG_SERIAL_8250_NR_UARTS=32
CONFIG_SERIAL_8250_RSA=y
CONFIG_SERIAL_8250_SHARE_IRQ=y
CONFIG_PRINTK_TIME=y
CONFIG_BOOT_PRINTK_DELAY=y

# For RO root support
CONFIG_EROFS_FS=y
CONFIG_EROFS_FS_XATTR=y

# --- Architecture ---
CONFIG_64BIT=y
CONFIG_X86_64=y
CONFIG_SMP=y

# --- PVH boot (Cloud Hypervisor direct kernel boot) ---
# Full dependency chain: HYPERVISOR_GUEST -> PARAVIRT -> XEN -> XEN_PVH -> PVH
CONFIG_HYPERVISOR_GUEST=y
CONFIG_PARAVIRT=y
CONFIG_XEN=y
CONFIG_XEN_PVH=y
CONFIG_PVH=y

# --- No legacy hardware ---
CONFIG_ACPI=y
CONFIG_PCI=y
CONFIG_PCIEPORTBUS=y
CONFIG_PCI_MSI=y
CONFIG_VGA_CONSOLE=n
CONFIG_FRAMEBUFFER_CONSOLE=n
CONFIG_DRM=n
CONFIG_SOUND=n
CONFIG_USB=n
CONFIG_INPUT=n
CONFIG_HID=n

# required by virtio_mem
CONFIG_MEMORY_HOTREMOVE=y

# --- Virtio (Cloud Hypervisor transport) ---
CONFIG_VIRTIO=y
CONFIG_VIRTIO_PCI=y
CONFIG_VIRTIO_MMIO=y
CONFIG_VIRTIO_BLK=y
CONFIG_VIRTIO_NET=y
CONFIG_VIRTIO_CONSOLE=y
CONFIG_VSOCKETS=y
CONFIG_VSOCKETS=y
CONFIG_VIRTIO_VSOCKETS=y
CONFIG_VIRTIO_VSOCKETS_COMMON=y
CONFIG_VHOST_VSOCK=n
CONFIG_VIRTIO_MEM=y

# --- Filesystems ---
CONFIG_FUSE_FS=y
CONFIG_VIRTIO_FS=y
CONFIG_OVERLAY_FS=y
CONFIG_TMPFS=y
CONFIG_PROC_FS=y
CONFIG_SYSFS=y
CONFIG_DEVTMPFS=y
CONFIG_DEVTMPFS_MOUNT=y

# --- Block layer ---
CONFIG_BLOCK=y
CONFIG_BLK_DEV=y

# required by ipc_ns
CONFIG_POSIX_MQUEUE=y

# --- Namespaces (container isolation) ---
CONFIG_NAMESPACES=y
CONFIG_UTS_NS=y
CONFIG_IPC_NS=y
CONFIG_USER_NS=y
CONFIG_PID_NS=y
CONFIG_NET_NS=y

# retuired for CONFIG_CGROUP_BPF
CONFIG_BPF_SYSCALL=y


# --- Cgroups v2 (container resource limits) ---
CONFIG_CGROUPS=y
CONFIG_CGROUP_FREEZER=y
CONFIG_CGROUP_PIDS=y
CONFIG_CGROUP_DEVICE=y
CONFIG_CGROUP_CPUACCT=y
CONFIG_CGROUP_PERF=n
CONFIG_CGROUP_BPF=y
CONFIG_MEMCG=y
CONFIG_BLK_CGROUP=y
CONFIG_CGROUP_SCHED=y
CONFIG_FAIR_GROUP_SCHED=y
CONFIG_CFS_BANDWIDTH=y

# --- Networking (minimal — container networking) ---
CONFIG_NET=y
CONFIG_NETDEVICES=y
CONFIG_INET=y
CONFIG_IPV6=y
CONFIG_NETFILTER=y
CONFIG_BRIDGE=y
CONFIG_VETH=y
CONFIG_TUN=n
CONFIG_PACKET=y
CONFIG_UNIX=y

# --- Security ---
CONFIG_SECCOMP=y
CONFIG_SECCOMP_FILTER=y
CONFIG_SECURITY=n
CONFIG_SELINUX=n
CONFIG_APPARMOR=n

# --- Memory management ---
CONFIG_TRANSPARENT_HUGEPAGE=n
CONFIG_MEMORY_HOTPLUG=y
CONFIG_MEMORY_HOTPLUG_DEFAULT_ONLINE=y
CONFIG_COMPACTION=y

# --- Disable unnecessary features ---
CONFIG_MODULES=n
CONFIG_SWAP=n
CONFIG_DEBUG_KERNEL=n
CONFIG_DEBUG_INFO=n
CONFIG_FTRACE=n
CONFIG_PRINTK=y
CONFIG_BUG=y
CONFIG_KALLSYMS=n
CONFIG_PROFILING=n
CONFIG_KPROBES=n
CONFIG_WIRELESS=n
CONFIG_WLAN=n
CONFIG_BLUETOOTH=n
CONFIG_NFS_FS=n
CONFIG_CRYPTO=y
CONFIG_CRYPTO_HW=n

# --- Fast boot ---

CONFIG_DETECT_HUNG_TASK=n
CONFIG_SCHED_DEBUG=n

# --- RNG for containers ---
CONFIG_HW_RANDOM=y
CONFIG_HW_RANDOM_VIRTIO=y
