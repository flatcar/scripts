From 9fc9b45b658af721a7d21113d332a664c23fe71f Mon Sep 17 00:00:00 2001
From: Daniel Zatovic <daniel.zatovic@gmail.com>
Date: Thu, 9 Oct 2025 16:04:01 +0200
Subject: [PATCH] units: allow @mount syscalls for systemd-udevd

In Flatcar we are using modprobe helpers that run depmod in temporary
overlay. systemd-udevd.service may try to load drivers for some block
devices (e.g. ZFS), which ends up calling our helpers, which invoke
mount command. The mount syscalls are forbidden by the default
systemd-udevd syscall filter.
---
 units/systemd-udevd.service.in | 2 ++
 1 file changed, 2 insertions(+)

diff --git a/units/systemd-udevd.service.in b/units/systemd-udevd.service.in
index f4a4482088..02d00c98ad 100644
--- a/units/systemd-udevd.service.in
+++ b/units/systemd-udevd.service.in
@@ -36,6 +36,8 @@ RestrictAddressFamilies=AF_UNIX AF_NETLINK AF_INET AF_INET6
 RestrictRealtime=yes
 RestrictSUIDSGID=yes
 SystemCallFilter=@system-service @module @raw-io bpf
+# needed for the Flatcar sysext modprobe helpers
+SystemCallFilter=@mount
 SystemCallFilter=~@clock
 SystemCallErrorNumber=EPERM
 SystemCallArchitectures=native
-- 
2.51.0

