#!/bin/bash

set -euo pipefail
rootfs="${1}"

DIR="$(dirname "$(realpath "${BASH_SOURCE[0]}")")"
. "$DIR/sysext_mangle_kmod"

pushd "${rootfs}"

# Drop dev/debug/initramfs files — the sysext only needs runtime bits.
rm -rf ./usr/{lib/debug/,lib64/cmake/,include/}
rm -rf ./usr/lib/dracut/
rm -rf ./usr/share/initramfs-tools
rm -rf ./usr/src
rm -rf ./usr/share/man
rm -rf ./usr/share/doc
rm -rf ./usr/lib/pkgconfig
rm -rf ./usr/lib64/pkgconfig

# /usr/sbin on Flatcar is a symlink to /usr/bin; shipping a /usr/sbin
# directory in a sysext would clobber the symlink at merge time. Relocate
# anything the tools ebuild installed there.
if [ -d ./usr/sbin ]; then
  mkdir -p ./usr/bin
  mv ./usr/sbin/* ./usr/bin/ 2>/dev/null || true
  rmdir ./usr/sbin
fi

# Wire up the out-of-tree module through the shared kmod helper. This
# installs modprobe.d entries and a helper script that overlays the
# kernel-modules directory at load time so bcachefs.ko can be inserted
# without violating the read-only /usr guarantee.
configure_modprobe flatcar-bcachefs

popd
